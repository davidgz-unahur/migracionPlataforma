import example.*

describe "Casos de prueba de etapa 1"{
  test "Al inicio, Objetos1 tiene un niuvel de presencialidad de 20"{
    assert.equals(20, objetos1.puntajeDeReputacion())
  }

  test "Si dicta una clase exitosamente usand Teletuvix, su nivel de..."{
    objetos1.dioClaseExitosa(teletuvix)
    assert.equals(34, objetos1.puntajeDeReputacion())
  }
}

